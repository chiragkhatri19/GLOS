# ─────────────────────────────────────────
# REQUIRED — Vision LLM API key
# Get from: https://aistudio.google.com
# ─────────────────────────────────────────
GEMINI_API_KEY=your_key_here

# Optional fallback keys (for rate limiting)
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=

# ─────────────────────────────────────────
# REQUIRED — Lingo.dev
# Get from: https://lingo.dev/dashboard
# ─────────────────────────────────────────
LINGODOTDEV_API_KEY=your_key_here

# ─────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3002
SUPABASE_URL=
SUPABASE_ANON_KEY=
